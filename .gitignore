software/

# 用户问卷原始数据（含邮箱 / 姓名 / IP，不入公开仓库）
# README.md 在该目录是说明文件，单独豁免
paper/user_study/raw/*
!paper/user_study/raw/README.md

# 图形输出
figures/
*.png
*.pdf
*.tiff
*.svg
!FINAL_reference_card.png
# paper/ 下的图是论文资产，必须入库（先豁免目录再豁免文件）
!paper/figures/
!paper/**/*.png
!paper/**/*.pdf
!paper/**/*.svg
!paper/**/*.tiff

# R
.Rhistory
.RData
.Rproj.user/

# 日志
logs/

# Zone.Identifier（Windows NTFS ADS 流，标记下载来源）
# 不同 shell 上 ADS 流分隔符可能显示为 ':' 或 unicode '\357\200\272' (U+F03A)，
# 用更宽松的 *Zone.Identifier 模式覆盖两者
*:Zone.Identifier
*Zone.Identifier

# 超过 GitHub 100MB 限制的论文 TIFF 原图（本地保留，不入仓库）
# 论文复现用：高分辨率 PDF/PNG 同名替代，或本地原图
paper/figures_thesis/paper_en/Fig3-3_MAG_gene_profile_EN.tiff
paper/figures_thesis/paper_en/Fig3-4_MAG_abundance_top30_EN.tiff

