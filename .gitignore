# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.ipynb_checkpoints/
.env

# 虚拟环境
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code 本地状态
.claude/

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Streamlit
.streamlit/secrets.toml

# 数据文件（本地数据不入库；样例数据在 tests/sample_data/ 例外）
data/
*.gephi

# 行政材料 / 软著 / 项目申报 / 期刊评价等机构内部文档（本地保留，不入公开仓库）
software/

# 用户问卷原始数据（含邮箱 / 姓名 / IP，不入公开仓库）
# README.md 在该目录是说明文件，单独豁免
paper/user_study/raw/*
!paper/user_study/raw/README.md

# 图形输出
figures/
*.png
*.pdf
*.tiff
*.svg
!FINAL_reference_card.png
# paper/ 下的图是论文资产，必须入库（先豁免目录再豁免文件）
!paper/figures/
!paper/**/*.png
!paper/**/*.pdf
!paper/**/*.svg
!paper/**/*.tiff

# 例外：paper/benchmarks/validation/ 下的 TIFF 是原研究 Python 脚本输出的
# 出版级图（240MB / 700MB 超 GitHub 100MB 限制），PDF/PNG 已足够论文 SI 用
paper/benchmarks/validation/**/*.tiff

# R
.Rhistory
.RData
.Rproj.user/

# 日志
logs/

# Zone.Identifier（Windows NTFS ADS 流，标记下载来源）
# 不同 shell 上 ADS 流分隔符可能显示为 ':' 或 unicode '\357\200\272' (U+F03A)，
# 用更宽松的 *Zone.Identifier 模式覆盖两者
*:Zone.Identifier
*Zone.Identifier

# 学位论文（课题）资产已迁出本仓库到本地 d:\workdata\envmeta_thesis\
# 防御性条目：万一这些目录被误新建，仍然不被追踪
paper/figures_thesis/
paper/tables_thesis/
paper/config_thesis/

# 杂项
--group
--input
--legend
Rscript
